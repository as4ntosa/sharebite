# ── Google Maps ─────────────────────────────────────────────────────────────
# Get a key at: https://console.cloud.google.com/  (enable Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Supabase ─────────────────────────────────────────────────────────────────
# Leave both blank to run in mock/demo mode (no database required).
# To enable real accounts + live listings:
#   1. Create a free project at https://supabase.com
#   2. Run supabase-schema.sql in the Supabase SQL editor
#   3. Copy your Project URL and anon key from:
#      Project Settings → API → Project URL / anon public
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
